{
  "name": "@luma.gl/devtools",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "playwright": "node ./playwright/website-playwright.mjs",
    "playwright:install": "playwright install chromium",
    "test-node": "vitest run --config ../vitest.config.ts --project node",
    "test-browser": "vitest run --config ../vitest.config.ts --project browser",
    "test-headless": "vitest run --config ../vitest.config.ts --project headless",
    "test-coverage": "vitest run --config ../vitest.config.ts --coverage --project headless"
  },
  "dependencies": {
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.56.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}

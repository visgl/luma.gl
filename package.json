{
  "name": "luma.gl-monorepo",
  "description": "WebGL2 Components for High Performance Rendering and Computation",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/luma.gl"
  },
  "keywords": [
    "webgl",
    "visualization",
    "animation",
    "3d"
  ],
  "workspaces": [
    "dev-modules/*",
    "modules/*",
    "examples/**/*",
    "website"
  ],
  "browser": {
    "fs": false
  },
  "scripts": {
    "bootstrap": "bash ./dev-modules/devtools-extensions/bootstrap.sh",
    "start": "open https://luma.gl/docs/getting-started",
    "build": "ocular-clean && (cd modules/constants && yarn pre-build) && ocular-build",
    "lint": "yarn workspace @luma.gl/devtools-extensions lint",
    "publish-beta": "ocular-publish version-only-beta",
    "publish-prod": "ocular-publish version-only-prod",
    "test": "yarn test-node && yarn test-headless",
    "test-node": "yarn workspace @luma.gl/devtools-extensions test-node",
    "test-browser": "yarn workspace @luma.gl/devtools-extensions test-browser",
    "test-headless": "yarn workspace @luma.gl/devtools-extensions test-headless",
    "test-coverage": "yarn workspace @luma.gl/devtools-extensions test-coverage",
    "examples:typecheck": "node ./scripts/examples-typecheck.mjs",
    "test-fast": "yarn lint && yarn test-node",
    "test-website": "yarn website:build",
    "website:build": "yarn workspace website-docusaurus build",
    "website:start": "yarn workspace website-docusaurus start",
    "website-debug": "yarn workspace @luma.gl/devtools-extensions website-debug",
    "playwright:install": "yarn workspace @luma.gl/devtools-extensions playwright:install",
    "metrics": "./scripts/metrics.sh && ocular-metrics"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@loaders.gl/core": "~4.4.0",
    "@loaders.gl/gltf": "~4.4.0",
    "@loaders.gl/polyfills": "~4.4.0",
    "@luma.gl/devtools-extensions": "workspace:*",
    "@math.gl/dggs-geohash": "^4.1.0",
    "@math.gl/dggs-quadkey": "^4.1.0",
    "@math.gl/dggs-s2": "^4.1.0",
    "@probe.gl/bench": "^4.1.1",
    "@probe.gl/stats": "^4.1.1",
    "@probe.gl/stats-widget": "^4.1.1",
    "@probe.gl/test-utils": "^4.1.1",
    "@types/tape-promise": "^4.0.6",
    "@vis.gl/dev-tools": "^1.0.2",
    "@vis.gl/ts-plugins": "^1.0.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "a5-js": "^0.8.0",
    "h3-js": "^4.4.0",
    "pre-commit": "^1.2.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/plugin-content-docs": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "cheerio": "1.0.0-rc.9",
    "typescript": "5.9.3",
    "tsconfig-paths": "^3.9.0",
    "ts-patch": "^3.3.0"
  },
  "packageExtensions": {
    "@loaders.gl/gltf@*": {
      "peerDependencies": {
        "@loaders.gl/core": "~4.4.0"
      }
    },
    "@loaders.gl/images@*": {
      "peerDependencies": {
        "@loaders.gl/core": "~4.4.0"
      }
    }
  },
  "pre-commit": [
    "test-fast"
  ],
  "dependencies": {
    "@math.gl/types": "^4.1.0",
    "@types/offscreencanvas": "^2019.7.3"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}

{
  "name": "luma.gl-monorepo",
  "description": "WebGL2 Components for High Performance Rendering and Computation",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/luma.gl"
  },
  "keywords": [
    "webgl",
    "visualization",
    "animation",
    "3d"
  ],
  "workspaces": [
    "modules/*",
    "examples/**/*"
  ],
  "browser": {
    "fs": false
  },
  "scripts": {
    "bootstrap": "yarn && ocular-bootstrap && yarn build",
    "start": "open https://luma.gl/docs/getting-started",
    "build": "ocular-clean && (cd modules/constants && yarn pre-build) && ocular-build",
    "lint": "ocular-lint",
    "publish-beta": "ocular-publish version-only-beta",
    "publish-prod": "ocular-publish version-only-prod",
    "test": "yarn test-node && yarn test-browser",
    "test-node": "vitest run --project node",
    "test-browser": "vitest run --project browser",
    "test-headless": "vitest run --project headless",
    "test-coverage": "vitest run --coverage --project node --project headless",
    "test-fast": "yarn lint && yarn test-node",
    "test-website": "cd website && yarn && yarn build && cd ..",
    "metrics": "./scripts/metrics.sh && ocular-metrics"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@loaders.gl/core": "4.4.0-alpha.18",
    "@loaders.gl/gltf": "4.4.0-alpha.18",
    "@loaders.gl/polyfills": "4.4.0-alpha.18",
    "@probe.gl/bench": "^4.1.1",
    "@probe.gl/stats": "^4.1.1",
    "@probe.gl/stats-widget": "^4.1.1",
    "@probe.gl/test-utils": "^4.1.1",
    "@types/tape-promise": "^4.0.6",
    "@vis.gl/dev-tools": "^1.0.2",
    "@vis.gl/ts-plugins": "^1.0.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint-plugin-tree-shaking": "^1.12.2",
    "nyc": "^18.0.0",
    "playwright": "^1.56.1",
    "pre-commit": "^1.2.2",
    "puppeteer": "^24.39.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "typescript": "^5.8.3",
    "tsconfig-paths": "^3.9.0",
    "ts-patch": "^3.3.0"
  },
  "pre-commit": [
    "test-fast"
  ],
  "dependencies": {
    "@math.gl/types": "^4.1.0",
    "@types/offscreencanvas": "^2019.7.3"
  },
  "packageManager": "yarn@4.13.0"
}

{
  "name": "website-docusaurus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "node ./scripts/sync-example-assets.mjs && docusaurus start",
    "build": "node ./scripts/sync-example-assets.mjs && docusaurus build",
    "build-staging": "STAGING=true yarn build",
    "lint": "npx tsc --noEmit",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "check": "yarn docusaurus-mdx-checker ../docs",
    "clear": "docusaurus clear",
    "clean": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "resolution_notes": {
    "cheerio": "@cmfcmf/docusaurus-search-local breaks with v1.0.0 production release"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.2",
    "@docusaurus/core": "^3.9.2",
    "@probe.gl/stats": "^4.1.1",
    "@probe.gl/stats-widget": "^4.1.1",
    "@vis.gl/docusaurus-website": "1.0.0-alpha.21",
    "clsx": "^1.1.1",
    "maplibre-gl": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.1.5"
  },
  "devDependencies": {
    "@cmfcmf/docusaurus-search-local": "^2.0.0",
    "@docusaurus/tsconfig": "^3.9.2",
    "docusaurus-mdx-checker": "^3.0.0"
  },
  "browserslist": {}
}

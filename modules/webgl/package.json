{
  "name": "@luma.gl/webgl",
  "version": "9.3.1",
  "description": "WebGL2 adapter for the luma.gl core API",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/luma.gl"
  },
  "keywords": [
    "webgl",
    "visualization",
    "animation",
    "3d"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    },
    "./webgl-constants": {
      "types": "./dist/webgl-constants.d.ts",
      "import": "./dist/webgl-constants.js",
      "require": "./dist/webgl-constants.cjs"
    },
    "./webgl-types": {
      "types": "./dist/webgl-types.d.ts",
      "import": "./dist/webgl-types.js",
      "require": "./dist/webgl-types.cjs"
    }
  },
  "files": [
    "src",
    "dist",
    "dist.min.js",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build-minified-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.min.js",
    "build-dev-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.dev.js --env=dev",
    "prepublishOnly": "npm run build-minified-bundle && npm run build-dev-bundle"
  },
  "peerDependencies": {
    "@luma.gl/core": "~9.3.0"
  },
  "dependencies": {
    "@math.gl/types": "^4.1.0",
    "@probe.gl/env": "^4.1.1"
  },
  "gitHead": "c636c34b8f1581eed163e94543a8eb1f4382ba8e"
}

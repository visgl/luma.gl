{
  "name": "@luma.gl/text",
  "version": "9.3.0",
  "private": true,
  "description": "3D geometry and Arrow-native 2D text utilities for luma.gl",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/luma.gl"
  },

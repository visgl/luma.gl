    "@luma.gl/core": "~9.3.0",
    "@mapbox/tiny-sdf": "^2.0.7",
    "@math.gl/core": "^4.1.0",
    "@math.gl/polygon": "^4.1.0",
    "apache-arrow": "^17.0.0"
